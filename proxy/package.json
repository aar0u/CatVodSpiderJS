{
  "name": "proxy",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env HEADLESS=false tsx --watch src/server.ts",
    "start": "tsx src/server.ts",
    "test:browser": "cross-env HEADLESS=false LOG_CONSOLE=true WAIT_SECONDS=12 tsx test-browser.ts",
    "lint": "eslint --fix . && prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\""
  },
  "prettier": {
    "trailingComma": "all"
  },
  "dependencies": {
    "axios": "1.13.2",
    "chalk": "5.6.2",
    "mime-types": "3.0.2",
    "playwright": "1.57.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "cross-env": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.4",
    "nodemon": "3.1.11",
    "prettier": "3.7.4",
    "tsx": "4.21.0"
  }
}
